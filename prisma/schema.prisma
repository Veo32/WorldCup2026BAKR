// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// 👤 جدول المستخدمين (Telegram Users)
model User {
  id         String   @id @default(uuid())
  telegramId String   @unique
  firstName  String   @default("")
  lastName   String   @default("")
  username   String   @default("")
  photoUrl   String   @default("")
  isPremium  Boolean  @default(false)
  lastSeen   DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([telegramId])
}

// ⚽ جدول حفظ التحليلات والتوقعات للمباريات
model Prediction {
  id             String   @id @default(uuid())
  matchId        String   @unique
  matchName      String
  analysisResult String
  modelUsed      String
  language       String   @default("EN")
  isPdfGenerated Boolean  @default(false)
  postedToTg     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([matchName])
}

// 📅 جدول جدولة المباريات (تستخدمه الـ Cron Jobs)
model Match {
  id                  String   @id @default(uuid())
  homeTeam            String
  awayTeam            String
  matchTime           DateTime
  status              String   @default("SCHEDULED")
  predictionPublished Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// 📊 جدول إحصائيات القناة ولوحة التحكم (Dashboard Stats)
model ChannelStat {
  id           String   @id @default(uuid())
  totalMatches Int      @default(0)
  successRate  Float    @default(0.0)
  activeUsers  Int      @default(0)
  updatedAt    DateTime @updatedAt
}

// 💰 جدول المبيعات والعمليات لتتبع مشترين تقارير الـ PDF من Gumroad
model Transaction {
  id            String   @id @default(uuid())
  buyerEmail    String
  gumroadSaleId String   @unique
  productName   String
  amountPaid    Float
  createdAt     DateTime @default(now())
}